# ── MongoDB ──────────────────────────────────────────────────────────────────
# Leave unset to use the bundled MongoDB 8 container (recommended for self-hosters).
# Set to your Atlas URI or external MongoDB to override the bundled container.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/examhelper

# Root password for the bundled MongoDB container
MONGO_ROOT_PASSWORD=changeme

# ── Server ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-secure-random-string

# URL where the server is reachable (used for auth cookies & email links)
BETTER_AUTH_URL=http://localhost:4000

# URL where the frontend is reachable (used for CORS)
FRONTEND_URL=http://localhost:3000

# ── Registration ─────────────────────────────────────────────────────────────
# "open"         — anyone can sign up (default for the cloud-hosted version)
# "invite-only"  — only the admin can create accounts (default for self-hosters)
REGISTRATION_MODE=invite-only

# Auto-create an admin account on first startup (optional).
# If REGISTRATION_MODE=invite-only and no admin exists yet, set these to bootstrap.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Omit to disable Google sign-in.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Email / Resend (optional) ─────────────────────────────────────────────────
# Omit to disable email verification and password reset emails.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Ports (optional) ─────────────────────────────────────────────────────────
# SERVER_PORT=4000
# WEB_PORT=3000
